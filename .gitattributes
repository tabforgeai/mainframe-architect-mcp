# Normalize line endings
* text=auto

# Java/XML — LF
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.properties text eol=lf

# COBOL/JCL — LF
*.cbl text eol=lf
*.cob text eol=lf
*.jcl text eol=lf
*.csd text eol=lf
*.bms text eol=lf

# Binary
*.jar binary
*.deb binary
*.rpm binary
*.exe binary
*.png binary
